// nextflow.config — alpsanger pipeline configuration

manifest {
    name        = 'alpsanger'
    description = 'Sanger sequencing nanobody annotation pipeline'
    version     = '1.0.0'
    nextflowVersion = '>=24.04.0'
    mainScript  = 'main.nf'
}

// ── output directory & publish mode ──────────────────────────
outputDir = params.outdir
workflow.output.mode = 'copy'

// ── default parameters ────────────────────────────────────────
params {
    input_dir        = "/vast/scratch/users/zeglinski.k/_work/example_sanger_data"
    out_dir          = "results"
    basecall         = true
    igblast_db       = "${projectDir}/bin/igblast_refs"
    igblast_organism = "alpaca"
    help             = false

    // Resource defaults
    max_memory = '32 GB'
    max_cpus   = 8
    max_time   = '24 h'
}

// ── process resource labels ───────────────────────────────────
process {
    withLabel: 'process_low' {
        cpus   = 1
        memory = '2 GB'
        time   = '1 h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
}

// ── profiles ──────────────────────────────────────────────────
profiles {

    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    docker {
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'

        process {
            withName: 'tracy_basecall' {
                container = 'community.wave.seqera.io/library/tracy:0.8.1--0988e4620d7132d3'
            }
            withName: 'seqkit_replace_gaps' {
                container = 'community.wave.seqera.io/library/seqkit:2.13.0--05c0a96bf9fb2751'
            }
            withName: 'igblast' {
                container = 'community.wave.seqera.io/library/igblast:1.22.0--df7afc24896f633e'
            }
            withName: 'postprocess' {
                container = 'community.wave.seqera.io/library/bioconductor-cellarepertorium_r-openxlsx_r-tidyverse:9cf9dbd8126bcd40'
            }
            withName: 'fastqc' {
                container = 'community.wave.seqera.io/library/fastqc:0.12.1--af7a5314d5015c29'
            }
            withName: 'multiqc' {
                container = 'community.wave.seqera.io/library/multiqc:1.33--ee7739d47738383b'
            }
        }
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--bind /vast,/stornext'

        process {
            withName: 'tracy_basecall' {
                container = 'oras://community.wave.seqera.io/library/tracy:0.8.1--869f2d602de8570b'
            }
            withName: 'seqkit_replace_gaps' {
                container = 'oras://community.wave.seqera.io/library/seqkit:2.13.0--205358a3675c7775'
            }
            withName: 'igblast' {
                container = 'oras://community.wave.seqera.io/library/igblast:1.22.0--3588511b44218582'
            }
            withName: 'postprocess' {
                container = 'oras://community.wave.seqera.io/library/bioconductor-cellarepertorium_r-openxlsx_r-tidyverse:c05a8219e22916a8'
            }
            withName: 'fastqc' {
                container = 'oras://community.wave.seqera.io/library/fastqc:0.12.1--104d26ddd9519960'
            }
            withName: 'multiqc' {
                container = 'oras://community.wave.seqera.io/library/multiqc:1.33--e3576ddf588fa00d'
            }
        }
    }

    conda {
        conda.enabled = true

        process {
            withName: 'tracy_basecall' {
                conda = 'bioconda::tracy=0.8.1'
            }
            withName: 'seqkit_replace_gaps' {
                conda = 'bioconda::seqkit=2.13.0'
            }
            withName: 'igblast' {
                conda = 'bioconda::igblast=1.22.0'
            }
            withName: 'postprocess' {
                conda = 'conda-forge::r-tidyverse=2.0.0 bioconda::bioconductor-cellarepertorium=1.12.0 conda-forge::r-openxlsx=4.2.5'
            }
            withName: 'fastqc' {
                container = 'bioconda::fastqc=0.12.1'
            }
            withName: 'multiqc' {
                container = 'bioconda::multiqc=1.21'
            }
        }
    }

    test {
        params {
            input_dir        = "${projectDir}/test/input"
            igblast_db       = "${projectDir}/bin/igblast_refs"
            basecall         = false
            out_dir          = 'test_results'
        }
    }
}

// ── tracing / reporting ───────────────────────────────────────
timeline {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/report.html"
}
trace {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/dag.svg"
}
