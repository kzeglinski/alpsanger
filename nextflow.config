// nextflow.config — alpsanger pipeline configuration

manifest {
    name        = 'alpsanger'
    description = 'Sanger sequencing nanobody annotation pipeline'
    version     = '1.0.0'
    nextflowVersion = '>=24.04.0'
    mainScript  = 'main.nf'
}

// ── output directory & publish mode ──────────────────────────
outputDir = params.outdir
workflow.output.mode = 'copy'

// ── default parameters ────────────────────────────────────────
params {
    input_dir        = "/vast/scratch/users/zeglinski.k/_work/example_sanger_data"
    out_dir          = "results"
    basecall         = true
    igblast_db       = "${projectDir}/bin/igblast_refs"
    igblast_organism = "alpaca"
    help             = false

    // Resource defaults
    max_memory = '32 GB'
    max_cpus   = 8
    max_time   = '24 h'
}

// ── process resource labels ───────────────────────────────────
process {
    withLabel: 'process_low' {
        cpus   = 1
        memory = '2 GB'
        time   = '1 h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8 GB'
        time   = '4 h'
    }
}

// ── profiles ──────────────────────────────────────────────────
profiles {

    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    docker {
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--bind /vast,/stornext'
    }
}

// ── tracing / reporting ───────────────────────────────────────
timeline {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/report.html"
}
trace {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    overwrite  = true
    file    = "${params.out_dir}/pipeline_info/dag.svg"
}
